#!/bin/bash
#SBATCH --partition=gpu_mig
#SBATCH --gpus=1
#SBATCH --job-name=incSummary
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=9
#SBATCH --time=02:00:00
#SBATCH --output=slurm_output/inc_summary_%A.out

module purge
module load 2025
module load Anaconda3/2025.06-1

source activate thesis

echo "=== ENV CHECK ==="
which python
python --version
python -c "import torch; print('torch:', torch.__version__); print('cuda:', torch.cuda.is_available()); print('gpu count:', torch.cuda.device_count())"

echo "=== HF CHECK ==="
hf auth whoami || true

srun python incr_summary.py \
  --input_csv local_kpa_claims.csv \
  --output_csv outputs/qwen_sample_with_incremental_summary.csv \
  --model_name Qwen/Qwen2.5-7B-Instruct